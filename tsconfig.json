{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": "./src",

    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "types": ["node"]
  }, 
    
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],

  "declaration": false,
  "sourceMap": true,


}


